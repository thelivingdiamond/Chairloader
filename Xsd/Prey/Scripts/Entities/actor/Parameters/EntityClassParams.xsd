                                    <xs:annotation>
                                      <xs:documentation>Array item<br /></xs:documentation>
                                    </xs:annotation>
                                    <xs:complexContent>
                                      <xs:extension base="MetaType">
                                        <xs:attribute name="class" type="string" />
                                        <xs:attribute ref="ch:index" use="required" />
                                      </xs:extension>
                                    </xs:complexContent>
                                  </xs:complexType>
                                </xs:element>
                                <xs:element name="ImpulseSet" minOccurs="0" maxOccurs="unbounded">
