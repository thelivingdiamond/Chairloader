                                                </xs:extension>
                                              </xs:complexContent>
                                            </xs:complexType>
                                          </xs:element>
                                        </xs:choice>
                                        <xs:attribute ref="ch:index" use="required" />
                                        <xs:anyAttribute processContents="skip" />
                                      </xs:extension>
                                    </xs:complexContent>
                                  </xs:complexType>
                                </xs:element>
                              </xs:choice>
                              <xs:attribute name="maxRagdollImpulse" type="float" />
                            </xs:extension>
