                                <xs:annotation>
                                  <xs:documentation>[READ-ONLY] </xs:documentation>
                                </xs:annotation>
                              </xs:attribute>
                              <xs:attribute name="Label" type="string" />
                              <xs:attribute name="DefaultSummary" type="string" />
                              <xs:attribute name="Description" type="string" />
